# ---------------------------------------------------------------------------
# BILL SPILT environment variables
# Copy to `.env.local` for local development. On Vercel, set these in the
# project's Environment Variables settings. Everything here is zero-cost and
# Vercel-native.
# ---------------------------------------------------------------------------

# Vercel Postgres (Neon) — added automatically when you create a Postgres store
# in the Vercel dashboard and link it to the project. These are the variables
# `@vercel/postgres` reads.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Optional TLS hardening for the `pg` (non-Neon) driver. By default the cert is
# not verified (managed providers often present certs outside the system trust
# store). To verify: set DATABASE_CA_CERT to the provider's CA (PEM), or
# DATABASE_SSL_STRICT=true to verify against the system trust store.
DATABASE_CA_CERT=
DATABASE_SSL_STRICT=

# Vercel Blob — receipt photo storage. Created via the Vercel dashboard
# (Storage > Blob). The read/write token is injected automatically when linked.
BLOB_READ_WRITE_TOKEN=

# Vercel KV (Upstash) — optional cache for settlement plans. The app works
# without it; if these are unset, settlement is computed on the fly.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# NextAuth.js v5 (Auth.js)
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=
# Optional in most deployments; set if NextAuth cannot infer the URL.
# AUTH_URL=https://your-app.vercel.app

# Secret that protects the cron endpoint. Vercel Cron sends this as a Bearer
# token via the `Authorization` header (configure in project settings).
CRON_SECRET=

# Comma-separated emails of site admins (app operators) who can manage ads and
# other app-wide settings. If unset, falls back to the operator email baked
# into lib/site-admin.ts.
SITE_ADMIN_EMAILS=

# --- Google AdSense (passive network ads) ---
# Your AdSense publisher id, e.g. ca-pub-1234567890123456. When set, the app
# loads the AdSense script + serves /ads.txt, and ad slots show network ads
# (Google fills them once your account/site is approved). Leave unset to use
# the built-in self-served house ads instead. These are NEXT_PUBLIC_ (exposed
# to the browser) — that's expected for AdSense.
NEXT_PUBLIC_ADSENSE_CLIENT=
# Optional default ad-unit slot id (numeric) created in your AdSense dashboard.
NEXT_PUBLIC_ADSENSE_SLOT=

# --- Email (password reset) ---
# Option 1 (recommended, easiest): Resend — free tier, just an API key.
# Sign up at resend.com, verify a domain you own (e.g. billspilt.com), create an
# API key, and set a From address on that domain.
RESEND_API_KEY=
RESEND_FROM=BILL SPILT <noreply@billspilt.com>

# Option 2 (fallback): SMTP, e.g. Gmail. Enable 2-Step Verification, create an
# App Password (Google Account → Security → App passwords), use it as SMTP_PASS.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=taylordrew4u@gmail.com
SMTP_PASS=
SMTP_FROM=taylordrew4u@gmail.com

# Public base URL — also used for SEO canonical URLs, the sitemap, and Open
# Graph image links. Set this to your real production domain; if it's wrong,
# search engines see the wrong canonical and ranking suffers.
NEXT_PUBLIC_APP_URL=https://billspilt.com

# Optional: Google Search Console verification token (Settings → Ownership
# verification → HTML tag → copy the content="..." value). Renders the
# google-site-verification meta tag so you can verify the domain and submit
# the sitemap. Left out entirely when unset.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: Bing Webmaster Tools verification token (Add site → HTML Meta Tag →
# copy the content="..." value from the msvalidate.01 tag). Also covers
# DuckDuckGo, which is powered by Bing. Left out entirely when unset.
NEXT_PUBLIC_BING_SITE_VERIFICATION=
