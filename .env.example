# ---------------------------------------------------------------------------
# BillBuddies environment variables
# Copy to `.env.local` for local development. On Vercel, set these in the
# project's Environment Variables settings. Everything here is zero-cost and
# Vercel-native.
# ---------------------------------------------------------------------------

# Vercel Postgres (Neon) — added automatically when you create a Postgres store
# in the Vercel dashboard and link it to the project. These are the variables
# `@vercel/postgres` reads.
POSTGRES_URL=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# Vercel Blob — receipt photo storage. Created via the Vercel dashboard
# (Storage > Blob). The read/write token is injected automatically when linked.
BLOB_READ_WRITE_TOKEN=

# Vercel KV (Upstash) — optional cache for settlement plans. The app works
# without it; if these are unset, settlement is computed on the fly.
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# NextAuth.js v5 (Auth.js)
# Generate a secret with: openssl rand -base64 32
AUTH_SECRET=
# Optional in most deployments; set if NextAuth cannot infer the URL.
# AUTH_URL=https://your-app.vercel.app

# Secret that protects the cron endpoint. Vercel Cron sends this as a Bearer
# token via the `Authorization` header (configure in project settings).
CRON_SECRET=
